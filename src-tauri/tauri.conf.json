{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Employees Management System",
  "version": "1.3.0",
  "identifier": "com.mohammed.employees-management-system",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Employees Management System",
        "width": 1100,
        "height": 750,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "resources": [],
    "active": true,
    "targets": "app",
    "icon": ["icons/icon.ico"]
  }
}
